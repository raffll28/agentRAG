# Ollama HTTP API (default matches local ollama serve)
OLLAMA_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=qwen3.5:9b
# Optional request timeout in seconds
# OLLAMA_TIMEOUT=120

# Concurrency and size limits (scalability)
# AGENT_MAX_CONCURRENT=4
# AGENT_MAX_PROMPT_CHARS=28000
# MEMORY_MAX_BYTES_PER_FILE_SEARCH=524288
# MEMORY_SEARCH_SNIPPET_CHARS=4000
# MEMORY_SEARCH_MAX_TOTAL_CHARS=48000
# READ_FILE_MAX_CHARS=200000
